# Copy to terraform.tfvars and fill in real values

megaport_access_key = "<megaport-api-access-key>"
megaport_secret_key = "<megaport-api-secret-key>"

# DX Gateway ID from root module: terraform -chdir=.. output dx_gateway_id
aws_dx_gateway_id = "08af4365-b80d-42d3-8fcf-f775401d3731"

aws_account_id = "211098808963"
