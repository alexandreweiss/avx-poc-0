megaport_location = "Equinix LD5"   # DX-connected, near eu-west-1
port_speed        = 1000
vxc_bandwidth     = 50

bgp_asn_customer = 65000
bgp_auth_key     = "<shared-bgp-secret>"
vlan             = 100
