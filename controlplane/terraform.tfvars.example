# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored.

aws_region = "eu-west-1"

controller_admin_email    = "you@example.com"
controller_admin_password = "ChangeMe-123!"
customer_id               = "xxxxxxx-abu-xxxxxxxxx"

access_account_name = "aws-poc"
account_email       = "you@example.com"

# Your public IP — restrict Controller access
incoming_ssl_cidrs = ["YOUR_PUBLIC_IP/32"]

# Optional overrides (defaults shown):
# controller_name          = "aviatrix-controller"
# controller_instance_type = "t3.large"
# controller_version       = "latest"
# controlplane_vpc_cidr    = "10.0.0.0/24"
# controlplane_subnet_cidr = "10.0.0.0/24"
